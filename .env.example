# Kid's name — shown in the welcome message
NUXT_PUBLIC_NAME=Kid

# Terminal prompt symbol
NUXT_PUBLIC_PROMPT_SYMBOL=>

# Prompt color (must be a key from TEXT_STYLES: RED, GREEN, YELLOW, BLUE, MAGENTA, CYAN, WHITE)
NUXT_PUBLIC_PROMPT_COLOR=MAGENTA

# Welcome message template ({{name}} and {{version}} are interpolated)
NUXT_PUBLIC_WELCOME_MESSAGE=FridOS v{{version}} — Welcome, {{name}}! Type HELP to get started.

# Comma-separated emojis used by the number command
NUXT_PUBLIC_EMOJIS=💖,🦄,🍍,🥐,🐢,🫐,🍓,🌈,💅,🐞,🪼,🦋
